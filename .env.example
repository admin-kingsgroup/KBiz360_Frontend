# ─── KBiz360 Books — frontend environment template ──────────────────────────
# Copy to `.env` (or `.env.local`) and fill in. Vite only exposes VITE_* vars.

# ERP / Books backend (Express). Must match kbiz360-erp-backend PORT (default 9090).
VITE_KBIZ_API_BASE=http://localhost:9090

# CRM backend base — used by the Payment Verification inbox (SSO to /payments/*).
VITE_CRM_API_BASE=http://localhost:5000/api

# Shared SSO token key (CRM stores the access token here on login).
VITE_AUTH_TOKEN_KEY=kb360-token

# Dev-only: a JWT signed with the backend's JWT_SECRET so the UI can load data
# without a CRM login. Leave blank in production (real login provides it via SSO).
# Generate one from the backend repo:
#   node -e "require('dotenv').config();const jwt=require('jsonwebtoken');console.log(jwt.sign({id:'dev',role:'super_admin',branches:['BOM']},process.env.JWT_SECRET,{expiresIn:'365d'}))"
VITE_KBIZ_DEV_TOKEN=
