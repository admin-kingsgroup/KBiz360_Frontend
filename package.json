{
  "name": "kbiz360-smart-travel-erp",
  "version": "1.1.0",
  "private": true,
  "description": "KBiz360 — The Business Engine. Smart Travel ERP for Travkings Tours & Travels.",
  "author": "Travkings Tours & Travels Pvt. Ltd.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "gen:routes": "node scripts/gen-route-manifest.cjs",
    "gen:devscan": "node scripts/gen-dev-scan.cjs",
    "gen": "node scripts/gen-route-manifest.cjs && node scripts/gen-dev-scan.cjs",
    "predev": "npm run gen",
    "prebuild": "npm run gen",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "pretest": "npm run gen",
    "test": "jest",
    "test:watch": "jest --watch",
    "rebuild": "npm install && npm run build",
    "redeploy": "npm install && npm run build && npm run preview",
    "demo:invoice": "esbuild scripts/gen-demo-invoice.mjs --bundle --platform=node --format=esm --resolve-extensions=.js,.jsx,.mjs,.json --loader:.js=jsx --define:import.meta.env={} --outfile=scripts/.demo-bundle.mjs && node scripts/.demo-bundle.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.1",
    "axios": "^1.18.0",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.12.7",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
